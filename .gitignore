# =============================================================================
# FireSwarm MARL Environment — .gitignore
# =============================================================================

# ---------------------------------------------------------------------------
# SECRETS — NEVER commit these
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example
*.key
*.pem
*.secret

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
wheels/
pip-wheel-metadata/
share/python-wheels/
.installed.cfg
MANIFEST

# ---------------------------------------------------------------------------
# Virtual environments
# ---------------------------------------------------------------------------
.venv/
venv/
env/
ENV/
.Python

# ---------------------------------------------------------------------------
# uv
# ---------------------------------------------------------------------------
# Keep uv.lock committed (ensures reproducible installs on HF Spaces)
# .python-version is also safe to commit if present

# ---------------------------------------------------------------------------
# Testing & coverage
# ---------------------------------------------------------------------------
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
*.cover
*.coveragerc
nosetests.xml
test-results/

# ---------------------------------------------------------------------------
# Type checkers & linters
# ---------------------------------------------------------------------------
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/
.pytype/

# ---------------------------------------------------------------------------
# IDEs & editors
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ---------------------------------------------------------------------------
# Docker build artefacts
# ---------------------------------------------------------------------------
.docker/

# ---------------------------------------------------------------------------
# Jupyter
# ---------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb_checkpoints

# ---------------------------------------------------------------------------
# Replay logs written by the environment at runtime
# ---------------------------------------------------------------------------
/tmp/fire_swarm_replays/

# ---------------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------------
*.log
*.pid
*.tmp


validate-submission.sh