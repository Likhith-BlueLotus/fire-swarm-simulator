# =============================================================================
# FireSwarm — environment variable template
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.
# =============================================================================

# ---------------------------------------------------------------------------
# MANDATORY — required by the hackathon spec and inference.py
# ---------------------------------------------------------------------------

# OpenAI-compatible LLM API base URL
# HuggingFace Router:  https://router.huggingface.co/v1
# OpenAI directly:     https://api.openai.com/v1
API_BASE_URL=https://router.huggingface.co/v1

# LLM model identifier
# Examples:
#   meta-llama/Meta-Llama-3.1-70B-Instruct   (via HF Router)
#   gpt-4o-mini                               (via OpenAI)
MODEL_NAME=meta-llama/Meta-Llama-3.1-70B-Instruct

# Your HuggingFace token (or OpenAI API key when using OpenAI directly)
# Get yours at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_...

# ---------------------------------------------------------------------------
# OPTIONAL
# ---------------------------------------------------------------------------

# FireSwarm server URL — defaults to http://localhost:7860 if not set
# Set to your deployed HF Space URL when running inference remotely:
#   OPENENV_ENDPOINT=https://your-username-fire-swarm-simulator.hf.space
OPENENV_ENDPOINT=http://localhost:7860

# Uvicorn worker count — default 1 (set to 2 on cpu-upgrade HF Space)
WORKERS=1
